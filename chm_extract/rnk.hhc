      <param name="Local" value="lemeat_s015.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="16: Meleklerde mirac, insanlarda şakk-ı kamer gibidir">
      <param name="Local" value="lemeat_s016.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="17: Kelime-i şehadetin burhanı içindedir">
      <param name="Local" value="lemeat_s017.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="18: Hayat bir çeşit tecelli-i vahdettir">
      <param name="Local" value="lemeat_s018.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="19: Ruh, vücud-u hâricî giydirilmiş bir kanundur">
      <param name="Local" value="lemeat_s019.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="20: Hayatsız vücud, adem gibidir">
      <param name="Local" value="lemeat_s020.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="21: Hayat sebebiyle karınca küreden büyük olur">
      <param name="Local" value="lemeat_s021.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="22: Nasraniyet islamiyete teslim olacak">
      <param name="Local" value="lemeat_s022.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="23: Tebeî nazar, muhali mümkün görür">
      <param name="Local" value="lemeat_s023.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="24: Kur'an ayine ister, vekil istemez">
      <param name="Local" value="lemeat_s024.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="25: Mübtıl, bâtılı hak nazarıyla alır">
      <param name="Local" value="lemeat_s025.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="26: Kudretin ayineleri çoktur">
      <param name="Local" value="lemeat_s026.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="27: Temessülün aksamı muhtelifedir">
      <param name="Local" value="lemeat_s027.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="28: Müstaid, müçtehid olabilir, müşerri olamaz">
      <param name="Local" value="lemeat_s028.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="29: Nur-u akıl, kalbden gelir">
      <param name="Local" value="lemeat_s029.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="30: Dimağda meratib-i ilim muhtelifedir, mültebise...">
      <param name="Local" value="lemeat_s030.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="31: Hazm olmayan ilim, telkin edilmemeli">
      <param name="Local" value="lemeat_s031.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="32: Tahrib esheldir. Zaif, tahribci olur">
      <param name="Local" value="lemeat_s032.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="33: Kuvvet hakka hizmetkar olmalı">
      <param name="Local" value="lemeat_s033.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="34: Bazen zıd, zıddını tazammun eder">
      <param name="Local" value="lemeat_s034.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="35: Menfaati esas tutan siyaset canavardır">
      <param name="Local" value="lemeat_s035.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="36: Kuva-yı insaniyye tahdid edilmediğinden cinayeti büyük olur">
      <param name="Local" value="lemeat_s036.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="37: Bazen hayır, şerre vasıta olur">
      <param name="Local" value="lemeat_s037.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="38: Gaye-i hayal olmazsa, enaniyet kuvvetleşir">
      <param name="Local" value="lemeat_s038.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="39: Hayat-ı ihtilal, mevt-i zekat, hayat-ı ribâdan çıkmış">
      <param name="Local" value="lemeat_s039.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="40: Beşer hayatını isterse, enva-ı ribayı öldürmeli">
      <param name="Local" value="lemeat_s040.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="41: Beşer esirliği parçaladığı gibi, ecirliği de parçalayacaktır">
      <param name="Local" value="lemeat_s041.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="42: Gayr-ı meşru tarîk, zıdd-ı maksuda gider">
      <param name="Local" value="lemeat_s042.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="43: Cebr ve İtizalde birer dâne-i hakikat bulunur">
      <param name="Local" value="lemeat_s043.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="44: Acz ve Cez biçarelerin kârıdır">
      <param name="Local" value="lemeat_s044.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="45: İp üstünde olan, yerde olanla döğüşse kaybeder">
      <param name="Local" value="lemeat_s045.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="46: Mübhem bir hüküm, külli bir hüküm değil">
      <param name="Local" value="lemeat_s046.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="47: Bazan küçük bir şey, büyük bir iş yapar">
      <param name="Local" value="lemeat_s047.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="48: Bazılara bir an, bir senedir">
      <param name="Local" value="lemeat_s048.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="49: Yalan, bir lafz-ı kâfirdir">
      <param name="Local" value="lemeat_s049.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="50: Şeriat ile medeniyet-i hâzıra müvazeneleri">
      <param name="Local" value="lemeat_s050.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="51: Paslanmış hüdâ yine elmastır">
      <param name="Local" value="lemeat_s051.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="52: Cehil, mecazı eline alsa hakikat yapar">
      <param name="Local" value="lemeat_s052.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="53: Mübalağa zemm-i zımnîdir">
      <param name="Local" value="lemeat_s053.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="54: Şöhret zalimedir">
      <param name="Local" value="lemeat_s054.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="55: Din ile Hayat kabil-i tefrik değildir">
      <param name="Local" value="lemeat_s055.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="56: Mevt, tevehhüm edildiği gibi dehşetli değildir">
      <param name="Local" value="lemeat_s056.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="57: Siyaset, efkar aleminde bir şeytandır, istiaze edilmeli">
      <param name="Local" value="lemeat_s057.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="58: Zaaf, hasmı teşci eder">
      <param name="Local" value="lemeat_s058.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="59: İslam siyaseti kendinden çıkmalı">
      <param name="Local" value="lemeat_s059.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="60: Beğendiğin şeyde ifrat etme">
      <param name="Local" value="lemeat_s060.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="61: İnadın gözü, meleği şeytan görür">
      <param name="Local" value="lemeat_s061.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="62: Beklemediğin yerde, bazen imdad alırsın">
      <param name="Local" value="lemeat_s062.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="63: Cemaatin maye-i hayatı, tesanüddür">
      <param name="Local" value="lemeat_s063.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="64: Kabul etmemek hakkındır, Red etmek hakkın olmaz">
      <param name="Local" value="lemeat_s064.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="65: Sevâd-ı a'zama ittiba etmeli">
      <param name="Local" value="lemeat_s065.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="66: Hakkı bulduktan sonra ehakk için ihtilâfı çıkarma">
      <param name="Local" value="lemeat_s066.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="67: İslamiyet, selm ve müsalemettir">
      <param name="Local" value="lemeat_s067.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="68: İcad ve cem-i ezdadda büyük bir hikmet var">
      <param name="Local" value="lemeat_s068.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="69: Kesretin tarefeyni vahdettir">
      <param name="Local" value="lemeat_s069.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="70: Meziyetin varsa hafâ türâbında kalsın">
      <param name="Local" value="lemeat_s070.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="71: Allahın rahmet ve gadabından fazla tahassüs hatadır">
      <param name="Local" value="lemeat_s071.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="72: Akibet-i dünyeviye, ikâb-ı uhrevîye delildir">
      <param name="Local" value="lemeat_s072.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="73: Beşerin rahatı, ihtiyar iktidariyle ma'kusen mütenasibdir">
      <param name="Local" value="lemeat_s073.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="74: Akil ul-lahm hayvanların helal rızkı">
      <param name="Local" value="lemeat_s074.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="75: İsraf sefahetin, sefahet sefaletin kapısıdır">
      <param name="Local" value="lemeat_s075.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="76: Zâika telgrafçıdır, telziz ile baştan çıkarma">
      <param name="Local" value="lemeat_s076.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="77: Niyet gibi, tarz-ı nazar dahi adeti ibadete çevirir">
      <param name="Local" value="lemeat_s077.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="78: İsim takmak, müsemmâyı bilmek yerine geçmez">
      <param name="Local" value="lemeat_s078.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="79: Böyle zamanda tereffühte izn-i şer'î bizi muhtar bırakmaz">
      <param name="Local" value="lemeat_s079.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="80: Lezzetin elemde, elemin lezzette">
      <param name="Local" value="lemeat_s080.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="81: Zaman olur ki, adem-i nimet nimettir">
      <param name="Local" value="lemeat_s081.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="82: Her musibette, bir cihet-i nimet var">
      <param name="Local" value="lemeat_s082.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="83: Büyük görünme küçülürsün">
      <param name="Local" value="lemeat_s083.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="84: Hasletlerin yerleri değişse, mahiyetleri değişir">
      <param name="Local" value="lemeat_s084.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="85: «El-hakku Ya'lû» bizzat, hem akibet muraddır">
      <param name="Local" value="lemeat_s085.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="86: Bir kısım desatir-i ictimaiye">
      <param name="Local" value="lemeat_s086.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="87: Karılar yuvalarından çıkıp beşeri yoldan çıkarmış, yuvalarına dönmeli">
      <param name="Local" value="lemeat_s087.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="88: Meyl-üt-tevsi mütedeyyinde olmazsa, meyl-üt-tahribtir">
      <param name="Local" value="lemeat_s088.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="89: Tasarruf-u kudretin vüs'ati, vesâit ve muinleri reddeder">
      <param name="Local" value="lemeat_s089.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="90: Melaike bir ümmettir, şeriat-ı fıtriye ile memurdur">
      <param name="Local" value="lemeat_s090.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="91: Madde rikkat peyda ettikçe, hayat şiddet peyda eder">
      <param name="Local" value="lemeat_s091.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="92: Maddiyyunluk, bir taun-u manevîdir">
      <param name="Local" value="lemeat_s092.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="93: Vücudda atalet yoktur">
      <param name="Local" value="lemeat_s093.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="94: Riba, islama zarar-ı mutlaktır">
      <param name="Local" value="lemeat_s094.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="95: Kur'an, kendi kendini himaye edip hâkimiyetini idame eder">
      <param name="Local" value="lemeat_s095.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="96: Talim-i nazariyattan ziyade, tezkir-i müsellemata ihtiyaç var">
      <param name="Local" value="lemeat_s096.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="97: Hadîs der ayete, sana yetişmek muhal">
      <param name="Local" value="lemeat_s097.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="98: Îcaz ile beyan-ı i'caz-ı Kur'an">
      <param name="Local" value="lemeat_s098.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="99: Kuran edebi ile Medeniyetin edebi muvazanesi">
      <param name="Local" value="lemeat_s099.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="100: Tarz-ı nazar ikidir, biri zulmettar, diğeri ziyadar">
      <param name="Local" value="lemeat_s100.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="101: Dallar semeratı rahmet namına takdim ediyor">
      <param name="Local" value="lemeat_s101.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="102: Fatihanın ahirinde işaret olunan üç yolun beyanı">
      <param name="Local" value="lemeat_s102.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="103: Hakiki bütün elem dalalette, bütün lezzet imandadır">
      <param name="Local" value="lemeat_s103.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="104: Kıssa-i Musa'nın tekrarında çıkan lemaat-ı i'caz">
      <param name="Local" value="lemeat_s104.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="105: Tekrar; Kur'anın bir sırrı">
      <param name="Local" value="lemeat_s105.htm">
      <param name="ImageNumber" value="11">
      </OBJECT>
    <LI> <OBJECT type="text/sitemap">
      <param name="Name" value="106: Bir insanla bir şeytanın bir meselede mücadeleleri">
      <param name="Local" value="lemeat_s106.htm">
